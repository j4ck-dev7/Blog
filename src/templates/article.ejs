<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - <%= article.title %></title>
    <link rel="stylesheet" href="/css/article.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body>
    <%- include('partials/_header', { user: user }) %>
    
    <main data-articleSlug="<%= article.slug %>" data-is-authenticated="<%= user ? 'true' : 'false' %>">
        <article class="article-detail">
            <h1 class="article-title"><%= article.title %></h1>
            <div class="article-content">
                <% article.content.forEach((block, index) => { %>

                    <% if (block.type === 'paragraph') { %>
                    <p class="paragraph"><%= block.text %></p>

                    <% } else if (block.type === 'image') { %>
                    <div class="image-block">
                        <img 
                        src="<%= block.url %>" 
                        alt="<%= block.alt || 'Imagem do artigo' %>"
                        loading="lazy">
                        <% if (block.caption) { %>
                        <p class="image-caption"><%= block.caption %></p>
                        <% } %>
                    </div>

                    <% } else if (block.type === 'imageGallery') { %>
                    <div class="image-gallery">
                        <% (block.images || []).forEach(img => { %>
                        <img 
                            src="<%= img.url %>" 
                            alt="<%= img.alt || '' %>"
                            loading="lazy">
                        <% }); %>
                    </div>

                    <% } else if (block.type === 'code') { %>
                    <pre><code><%= block.code || '' %></code></pre>

                    <% } else if (block.type === 'list') { %>
                    <% if (block.style === 'ordered') { %>
                        <ol>
                        <% (block.items || []).forEach(item => { %>
                            <li><%= item %></li>
                        <% }); %>
                        </ol>
                    <% } else { %>
                        <ul>
                        <% (block.items || []).forEach(item => { %>
                            <li><%= item %></li>
                        <% }); %>
                        </ul>
                    <% } %>

                    <% } %>

                <% }); %>
            </div>
            <div class="article-meta">
                <span class="article-author"><%= article.author %></span>
                <span class="article-date">
                    <%= new Date(article.creationDate).toLocaleDateString('pt-BR') %>
                </span>
            </div>
        </article>
        
        <!-- Seção de Interações -->
        <div class="interactions-section">
            <div class="interactions-container">
                <div class="like-section">
                    <button class="like-button <% if (user && user.likedArticles && user.likedArticles.includes(article.id)) { %>filled<% } %>" 
                            id="like-btn" 
                            title="curtir o artigo"
                            data-articleSlug="<%= article.slug %>"
                            data-is-liked="<%= user && user.likedArticles && user.likedArticles.includes(article.id) ? 'true' : 'false' %>">
                        <% if (user && user.likedArticles && user.likedArticles.includes(article.id)) { %>
                            ♥
                        <% } else { %>
                            ♡
                        <% } %>
                    </button>
                    <span class="like-text" id="like-text"><%= article.likeCount %> curtidas</span>
                </div>
            </div>
        </div>
        
        <!-- Seção de Comentários -->
        <div class="comments-section">
            <h3 class="comments-header">Comentários</h3>
            
            <!-- Formulário de Comentário -->
            <% if (user) { %>
                <form class="comment-form" id="comment-form">
                    <textarea class="comment-input" 
                              id="comment-content" 
                              placeholder="Digite seu comentário..." 
                              required></textarea>
                    <button type="submit" class="comment-submit">Postar</button>
                </form>
            <% } else { %>
                <p class="login-prompt">
                    <a href="/app/auth/register" class="login-link">Faça login</a> para comentar.
                </p>
            <% } %>
            
            <!-- Lista de Comentários -->
            <div class="comments-list" id="comments-list">
                <% if (comments && comments.length > 0) { %>
                    <% comments.forEach(comment => { %>
                        <div class="comment-item" data-comment-id="<%= comment.id %>">
                            <div class="comment-header">
                                <div class="comment-author-date">
                                    <span class="comment-author"><%= comment.author %></span>
                                    <span class="comment-date"><%= new Date(comment.creationDate).toLocaleDateString('pt-BR') %></span>
                                </div>
                                <% if (user && user.id === comment.userId) { %>
                                    <div class="comment-actions">
                                        <a class="comment-action-btn edit-comment-btn" 
                                           data-comment-id="<%= comment.id %>">
                                            Editar
                                        </a>
                                        <a class="comment-action-btn delete-comment-btn" 
                                           data-comment-id="<%= comment.id %>">
                                            Excluir
                                        </a>
                                    </div>
                                <% } %>
                            </div>
                            <div class="comment-text"><%= comment.content %></div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="no-comments">Nenhum comentário ainda. Seja o primeiro a comentar!</p>
                <% } %>
            </div>
        </div>
    </main>
    
    <footer>
        <div class="container">
            <%- include('partials/_footer') %>
        </div>
    </footer>

    <script src="/js/header.js"></script>
    <script src="/js/article.js"></script>
</body>
</html>