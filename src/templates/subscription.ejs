<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - Assinaturas</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body>
    <%- include('partials/_header', { user: user }) %>
    
    <main>
        <div class="subscription-container">
            <h1 class="subscription-title">Escolha seu plano de assinatura</h1>
            
            <div class="subscription-cards">
                <!-- Card Basic -->
                <div class="subscription-card" data-plan="basic">
                    <div class="subscription-card-header">
                        <h2 class="subscription-card-title">Basic</h2>
                        <span class="subscription-card-badge <% if (user && user.subscriptionPlan === 'basic') { %>current<% } %>">
                            <% if (user && user.subscriptionPlan === 'basic') { %>Ativo<% } else { %>Popular<% } %>
                        </span>
                    </div>
                    <div class="subscription-card-price">R$ 5,00 <span class="subscription-card-period">/mês</span></div>
                    <ul class="subscription-card-features">
                        <li><i class="fas fa-check"></i> Acesso a artigos básicos</li>
                        <li><i class="fas fa-check"></i> Comentários ilimitados</li>
                        <li><i class="fas fa-check"></i> Curtidas ilimitadas</li>
                        <li class="disabled"><i class="fas fa-times"></i> Acesso a conteúdo premium</li>
                        <li class="disabled"><i class="fas fa-times"></i> Suporte prioritário</li>
                    </ul>
                    <% if (user && user.subscriptionPlan === 'basic') { %>
                        <button class="subscription-button current" disabled>Plano Atual</button>
                    <% } else if (user && (user.subscriptionPlan === 'intermediate' || user.subscriptionPlan === 'premium')) { %>
                        <button class="subscription-button" disabled>Plano Inferior</button>
                    <% } else { %>
                        <button class="subscription-button" data-plan="basic">Assinar</button>
                    <% } %>
                </div>

                <!-- Card Intermediate -->
                <div class="subscription-card" data-plan="intermediate">
                    <div class="subscription-card-header">
                        <h2 class="subscription-card-title">Intermediate</h2>
                        <span class="subscription-card-badge <% if (user && user.subscriptionPlan === 'intermediate') { %>current<% } %>">
                            <% if (user && user.subscriptionPlan === 'intermediate') { %>Ativo<% } else { %>Recomendado<% } %>
                        </span>
                    </div>
                    <div class="subscription-card-price">R$ 7,00 <span class="subscription-card-period">/mês</span></div>
                    <ul class="subscription-card-features">
                        <li><i class="fas fa-check"></i> Acesso a artigos básicos</li>
                        <li><i class="fas fa-check"></i> Comentários ilimitados</li>
                        <li><i class="fas fa-check"></i> Curtidas ilimitadas</li>
                        <li><i class="fas fa-check"></i> Acesso a conteúdo premium</li>
                        <li class="disabled"><i class="fas fa-times"></i> Suporte prioritário</li>
                    </ul>
                    <% if (user && user.subscriptionPlan === 'intermediate') { %>
                        <button class="subscription-button current" disabled>Plano Atual</button>
                    <% } else if (user && user.subscriptionPlan === 'premium') { %>
                        <button class="subscription-button" disabled>Plano Inferior</button>
                    <% } else { %>
                        <button class="subscription-button" data-plan="intermediate">Assinar</button>
                    <% } %>
                </div>

                <!-- Card Premium -->
                <div class="subscription-card" data-plan="premium">
                    <div class="subscription-card-header">
                        <h2 class="subscription-card-title">Premium</h2>
                        <span class="subscription-card-badge <% if (user && user.subscriptionPlan === 'premium') { %>current<% } %>">
                            <% if (user && user.subscriptionPlan === 'premium') { %>Ativo<% } else { %>Top<% } %>
                        </span>
                    </div>
                    <div class="subscription-card-price">R$ 10,00 <span class="subscription-card-period">/mês</span></div>
                    <ul class="subscription-card-features">
                        <li><i class="fas fa-check"></i> Acesso a artigos básicos</li>
                        <li><i class="fas fa-check"></i> Comentários ilimitados</li>
                        <li><i class="fas fa-check"></i> Curtidas ilimitadas</li>
                        <li><i class="fas fa-check"></i> Acesso a conteúdo premium</li>
                        <li><i class="fas fa-check"></i> Suporte prioritário</li>
                    </ul>
                    <% if (user && user.subscriptionPlan === 'premium') { %>
                        <button class="subscription-button current" disabled>Plano Atual</button>
                    <% } else { %>
                        <button class="subscription-button" data-plan="premium">Assinar</button>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
    
    <footer>
        <div class="container">
            <%- include('partials/_footer') %>
        </div>
    </footer>

    <script src="/js/header.js"></script>
    <script src="/js/subscription.js"></script>
</body>
</html>
