<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog - Artigos</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            color: #333;
            background-color: #000000;
        }
        
        header {
            color: #fff;
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            font-size: 1rem;
            font-weight: 600;
        }
        
        .user-section {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }
        
        .user-section a {
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }
        
        .user-section a:hover {
            color: #555;
        }
        
        main {
            max-width: 964px;
            margin: 2.7rem auto;
            padding: 1.5rem;
        }
        
        .articles-section {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.9rem;  
        }
        
        .article-card {
            width: 100%;
        }
        
        .article-title {
            font-size: 1.1rem;
            color: #ffffff;
            font-weight: 500;
        }
        
        .article-title a {
            color: #ffffff;
            text-decoration: none;
        }
        
        .article-title a:hover {
            text-decoration: underline;
        }
        
        .article-meta {
            display: flex;
            gap: 1rem;
            font-size: 0.8rem;
            color: #d0c5b8;
        }
        
        footer {
            width: 100%;
        }

        .container{
            max-width: 964px;
            margin: auto;
            padding-inline: 1.5rem;
            padding-top: 1rem;
        }

        .footer-div{
            text-align: center;
            padding: 2rem;
            width: 100%;
            display: flex;
            justify-content: space-between;
            border-top: 1px solid #706450;
        }
        
        .pagination {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 2rem;
        }
        
        .pagination a {
            color: #31bcff;
            font-size: 1.1rem;
            text-decoration: none;
        }

        .pagination span {
            color: #d0c5b8;
            font-size: 1.1rem;
        }
        
        .pagination a:hover {
            text-decoration: underline;
        }

        .footer-logo p{
            color: #ffffff;
        }

        .link a{
            color: #31bcff;
            text-decoration: none;
        }

        .link a:hover{
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <%- include('partials/_header', { user: user }) %>
    
    <main>        
        <% if (articles && articles.length > 0) { %>
            <div class="articles-section">
                <% articles.forEach(article => { %>
                    <article class="article-card">
                        <h2 class="article-title">
                            <a href="/article/<%= article.slug %>"><%= article.title %></a>
                        </h2>
                        <div class="article-meta">
                            <span class="article-likes">
                                <%= article.likeCount %> curtidas
                            </span>
                            <span class="article-comments">
                                <%= article.commentCount %> comentários
                            </span>
                            <span class="article-views">
                                <%= article.viewsCount %> visualizações
                            </span>
                            <span class="article-author"><%= article.author %></span>
                            <span class="article-date">
                                <%= new Date(article.creationDate).toLocaleDateString('pt-BR') %>
                            </span>
                        </div>
                    </article>
                <% }); %>
            </div>
            
            <% if (pagination) { %>
                <div class="pagination">
                    <% if (pagination.hasPrev) { %>
                        <a href="?page=<%= pagination.currentPage - 1 %>&limit=<%= pagination.limit %>"> &lt; Anterior</a>
                    <% } else { %>
                        <span>&lt; Anterior</span>
                    <% } %>
                    
                    <% if (pagination.hasNext) { %>
                        <a href="?page=<%= pagination.currentPage + 1 %>&limit=<%= pagination.limit %>">Próximo &gt;</a>
                    <% } else { %>
                        <span>Próximo &gt;</span>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <p>Nenhum artigo encontrado.</p>
        <% } %>
    </main>
    
    <footer>
        <div class="container">
            <%- include('partials/_footer') %>
        </div>
    </footer>
</body>
</html>
