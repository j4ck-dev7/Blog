<header>
    <div class="logo">Blog</div>
    <div class="header-controls">
        <div class="search-container" style="max-width: 300px; height: 32px; padding-inline: 13px;">
            <form action="/search" method="GET" style="display: flex; height: 100%;">
                <input type="text" name="q" placeholder="Pesquisar..." style="width: 100%; height: 100%; border: none; background: transparent; color: #fff; outline: none;">
            </form>
        </div>
        <button id="theme-toggle" style="background: none; border: none; cursor: pointer; color: #fff; font-size: 1.2rem; padding: 0 8px;">
            <span id="theme-icon">🌙</span>
        </button>
        <div class="user-section">
            <% if (user && user.authenticationType) { %>
                <% if (user.authenticationType === 'local') { %>
                    <a href="/user/menu">Menu do Usuário</a>
                <% } else if (user.authenticationType === 'google' || user.authenticationType === 'Oauth2') { %>
                    <a href="/auth/oauth">Login com OAuth</a>
                <% } %>
            <% } else { %>
                <a href="/app/auth/login">Login</a>
                <a href="/app/auth/register">Cadastrar</a>
            <% } %>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggle = document.getElementById('theme-toggle');
            const themeIcon = document.getElementById('theme-icon');
            const body = document.body;
            
            // Verificar preferência salva ou sistema
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            let isDark = savedTheme ? savedTheme === 'dark' : prefersDark;
            
            // Aplicar tema
            updateTheme(isDark);
            
            // Toggle ao clicar
            themeToggle.addEventListener('click', function() {
                isDark = !isDark;
                updateTheme(isDark);
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
            
            function updateTheme(isDarkMode) {
                if (isDarkMode) {
                    body.style.backgroundColor = '#000000';
                    body.style.color = '#333';
                    themeIcon.textContent = '🌙';
                    // Textos brancos se mantém brancos
                    document.querySelectorAll('header, .logo, .user-section a, .article-title, .article-title a, .article-meta, .pagination a, .pagination span, .footer-logo p, .link a').forEach(el => {
                        el.style.color = '#fff';
                    });
                } else {
                    body.style.backgroundColor = '#ffffff';
                    body.style.color = '#333';
                    themeIcon.textContent = '☀️';
                    // Textos brancos ficam pretos
                    document.querySelectorAll('header, .logo, .user-section a, .article-title, .article-title a, .article-meta, .pagination a, .pagination span, .footer-logo p, .link a').forEach(el => {
                        el.style.color = '#333';
                    });
                    // Specific overrides for elements that should stay light
                    document.querySelectorAll('.article-meta').forEach(el => {
                        el.style.color = '#666';
                    });
                    document.querySelectorAll('.pagination span').forEach(el => {
                        el.style.color = '#666';
                    });
                }
            }
        });
    </script>
</header>