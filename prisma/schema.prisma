generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" // Ao modificar | criar algum modelo é necessário usar o comando no terminal npx prisma migrate dev
} // depois execute no terminal npx prisma generate para que as alterações sejam recebidas para execução de um CRUD 

datasource db {
  provider = "postgresql"
}

model Comment {
  id String @id @default(cuid()) @db.VarChar(30) // Para dados públicos, como IDs expostos em URLs, usar cuid() é uma boa prática para garantir unicidade e segurança. Além disso as referencias também tem quer ser cuid()
  post String 
  user User @relation(fields: [userName], references: [name]) // Normalmente se usa o id para referenciar, mas nesse caso usamos o name para exemplificar outra forma de relacionamento (desnormalização), Isso evita joins desnecessários em consultas frequentes.
  userName String
  userId String
  articleSlug String
  creationDate DateTime @default(now())

  @@index([articleSlug]) // index de consultas
}
 
model Like {
  id String @id @default(cuid()) @db.VarChar(30) // Ao usar cuid(), é necessário definir o tamanho do campo no banco de dados com @db.VarChar(30), para evitar truncamentos. Isso nas versões 2.x ou superior do Prisma.
  articleSlug String
  userId String
  dateCreated DateTime @default(now())

  @@index([articleSlug]) // index de consultas
}

model User {
  id String @id @default(cuid()) @db.VarChar(30) // Definir o tamanho do campo para cuids gerados também assegura compatibilidade e otimização no postgres.
  name String @unique @db.VarChar(50)
  email String @unique @db.VarChar(50)
  password String? @db.VarChar(100)
  comment Comment[]
  role Role @default(user)
  createdAt DateTime @default(now())
  sub String? @db.VarChar(50) @unique
  authenticationType AuthenticationType @default(local)
  status Status @default(pending)
  isEmailVerified Boolean @default(false)

  @@index([name]) // index de consultas
  @@index([email]) // index de consultas
  @@index([sub])
}

enum Status {
  pending
  active
  blocked
}

enum AuthenticationType {
  google
  local
}

enum Role {
  admin
  user
}
